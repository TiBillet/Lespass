#!/bin/bash
set -e

# Script de préparation des dépendances Node.js pour LaBoutik
# Usage: ./install-modules-nodejs <pi|desktop>
#   pi       : Utilise install_pi/package.json et configure env.js pour pi
#   desktop  : Utilise install_desktop/package.json et configure env.js pour desktop

PLATFORM="$1"

# Vérification de l'argument
if [ -z "$PLATFORM" ]; then
    echo "Usage: $0 <pi|desktop>"
    echo ""
    echo "Plateformes disponibles :"
    echo "  pi       Prépare le projet pour Raspberry Pi (RC522 SoftSPI)"
    echo "  desktop  Prépare le projet pour Desktop (ACR122U USB)"
    exit 1
fi

# Validation de l'argument
if [ "$PLATFORM" != "pi" ] && [ "$PLATFORM" != "desktop" ]; then
    echo "Erreur: Plateforme '$PLATFORM' non reconnue"
    echo "Usage: $0 <pi|desktop>"
    exit 1
fi

# Déterminer le répertoire source du package.json
if [ "$PLATFORM" = "pi" ]; then
    SOURCE_DIR="install_pi"
    echo "Préparation pour Raspberry Pi..."
else
    SOURCE_DIR="install_desktop"
    echo "Préparation pour Desktop..."
fi

# Vérifier que le fichier package.json existe
if [ ! -f "$SOURCE_DIR/package.json" ]; then
    echo "Erreur: $SOURCE_DIR/package.json introuvable"
    exit 1
fi

# Nettoyage
echo "Nettoyage des dépendances existantes..."
if [ -d "node_modules" ]; then
    echo "  Suppression de node_modules/"
    rm -rf node_modules
fi

if [ -f "package-lock.json" ]; then
    echo "  Suppression de package-lock.json"
    rm -f package-lock.json
fi

# Copie du package.json
echo "Copie de $SOURCE_DIR/package.json vers la racine..."
cp "$SOURCE_DIR/package.json" ./package.json

# Configuration de env.js
echo "Configuration de env.js pour la plateforme $PLATFORM..."
if [ "$PLATFORM" = "pi" ]; then
    sed -i "s/type_app: 'desktop'/type_app: 'pi'/" env.js
    echo "  type_app défini sur 'pi'"
else
    sed -i "s/type_app: 'pi'/type_app: 'desktop'/" env.js
    echo "  type_app défini sur 'desktop'"
fi

# Installation des dépendances
echo "Installation des dépendances (npm install)..."
npm install

echo ""
echo "Préparation terminée avec succès !"
echo "Plateforme: $PLATFORM"
echo "Dépendances installées depuis: $SOURCE_DIR/package.json"
echo "Configuration: env.js mis à jour pour $PLATFORM"
