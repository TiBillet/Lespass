# --- Identité de la tireuse ---
TIREUSE_BEC=b7100a7b-a1ff-4664-b2a0-e5b47d992d8a

# --- Lecteur RFID (choisissez un type) ---
RFID_TYPE=RC522
# RFID_TYPE=VMA405
# RFID_TYPE=ACR122U

# Pour VMA405 uniquement (ignorez si RC522 ou ACR122U)
#RFID_SERIAL_PORT=/dev/ttyUSB0
#RFID_BAUDRATE=9600

# Pour RC522 uniquement : bus SPI (0=SPI0, 1=SPI1) et vitesse en Hz (défaut : SPI0 à 1 MHz)
#RC522_SPI_DEVICE=0
#RC522_SPI_SPEED=1000000

# --- Vanne ---
# GPIO_VANNE : pin BCM lue par hardware/valve.py (driver pigpio)
GPIO_VANNE=12
VALVE_ACTIVE_HIGH=False

# --- Débitmètre ---
# GPIO_FLOW_SENSOR : pin BCM lue par hardware/flow_meter.py (driver pigpio)
GPIO_FLOW_SENSOR=16
FLOW_CALIBRATION_FACTOR=6.5

# --- Backend ---
API_URL=http://192.168.1.10:8000
BACKEND_HOST=192.168.1.10
BACKEND_PORT=8000
BACKEND_API_KEY=changeme
NETWORK_TIMEOUT=5.0
MAX_RETRIES=3
DEBUG=False

# --- Logs ---
LOG_LEVEL=INFO

# --- Systemd ---
SYSTEMD_NOTIFY=True

# --- Git Update (mise à jour auto au démarrage) ---
GIT_REPO=https://github.com/TiBillet/tiheureuse.git
GIT_BRANCH=master
